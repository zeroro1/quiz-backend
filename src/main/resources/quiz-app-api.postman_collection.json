{
  "variable": {
    "key": "baseUrl",
    "value": "http://localhost:8080"
  },
  "info": {
    "name": "Quiz App API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. 微信登录",
      "request": {
        "url": {
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/wx/login",
          "path": [
            "api",
            "wx",
            "login"
          ]
        },
        "method": "POST",
        "body": {
          "raw": "{\\n  \"code\": \"wx_login_code_here\"\\n}",
          "mode": "raw"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "2. 更新用户信息",
      "request": {
        "url": {
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/wx/updateUserInfo",
          "path": [
            "api",
            "wx",
            "updateUserInfo"
          ]
        },
        "method": "POST",
        "body": {
          "raw": "{\\n  \"userId\": 1,\\n  \"nickname\": \"张三\",\\n  \"avatar\": \"https://example.com/avatar.png\"\\n}",
          "mode": "raw"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "3. 创建测试用户 (Admin)",
      "request": {
        "url": {
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/admin/createUser",
          "path": [
            "api",
            "admin",
            "createUser"
          ]
        },
        "method": "POST",
        "body": {
          "raw": "{\\n  \"openid\": \"test_openid_001\",\\n  \"nickname\": \"测试用户A\",\\n  \"avatar\": \"\"\\n}",
          "mode": "raw"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "4. 开始答题",
      "request": {
        "url": {
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/quiz/start",
          "path": [
            "api",
            "quiz",
            "start"
          ]
        },
        "method": "POST",
        "body": {
          "raw": "{\\n  \"userId\": 1\\n}",
          "mode": "raw"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "5. 提交答案",
      "request": {
        "url": {
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/quiz/submit",
          "path": [
            "api",
            "quiz",
            "submit"
          ]
        },
        "method": "POST",
        "body": {
          "raw": "{\\n  \"sessionId\": 1,\\n  \"userId\": 1,\\n  \"answers\": [\\n    {\"questionIndex\": 0, \"answer\": \"A\", \"timeTaken\": 12},\\n    {\"questionIndex\": 1, \"answer\": \"B\", \"timeTaken\": 8},\\n    {\"questionIndex\": 2, \"answer\": \"C\", \"timeTaken\": 15},\\n    {\"questionIndex\": 3, \"answer\": \"A\", \"timeTaken\": 10},\\n    {\"questionIndex\": 4, \"answer\": \"B\", \"timeTaken\": 20},\\n    {\"questionIndex\": 5, \"answer\": \"C\", \"timeTaken\": 14},\\n    {\"questionIndex\": 6, \"answer\": \"A\", \"timeTaken\": 9},\\n    {\"questionIndex\": 7, \"answer\": \"D\", \"timeTaken\": 11},\\n    {\"questionIndex\": 8, \"answer\": \"B\", \"timeTaken\": 16},\\n    {\"questionIndex\": 9, \"answer\": \"C\", \"timeTaken\": 7}\\n  ]\\n}",
          "mode": "raw"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "6. 常识排行榜",
      "request": {
        "method": "GET",
        "url": {
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/leaderboard/COMMONSENSE",
          "path": [
            "api",
            "leaderboard",
            "COMMONSENSE"
          ]
        },
        "header": []
      }
    },
    {
      "name": "7. 逻辑排行榜",
      "request": {
        "method": "GET",
        "url": {
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/leaderboard/LOGIC",
          "path": [
            "api",
            "leaderboard",
            "LOGIC"
          ]
        },
        "header": []
      }
    },
    {
      "name": "8. 我的答题记录",
      "request": {
        "method": "GET",
        "url": {
          "query": [
            {
              "key": "userId",
              "value": "1"
            }
          ],
          "host": "{{baseUrl}}",
          "raw": "{{baseUrl}}/api/user/records?userId=1",
          "path": [
            "api",
            "user",
            "records"
          ]
        },
        "header": []
      }
    }
  ]
}